# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.XXXX:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.XXXX:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="run: openssl rand -base64 32"
NEXTAUTH_URL="https://yourdomain.com"

# ─── Owner ───────────────────────────────────────────────────────────────────
OWNER_EMAIL="irayaian15@gmail.com"
NEXT_PUBLIC_OWNER_EMAIL="irayaian15@gmail.com"
ADMIN_SECRET_TOKEN="run: openssl rand -base64 32"

# ─── Logging ─────────────────────────────────────────────────────────────────
# Options: debug | info | warn | error (default: info in prod, debug in dev)
LOG_LEVEL="info"

# ─── Email notifications (Resend) ────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM="SafariOps <noreply@yourdomain.com>"

# ─── WhatsApp notifications (Twilio) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
OWNER_WHATSAPP="+254700000000"
